# ─── Job Ops — Local Development Environment ─────────────────────────────────
#
# Copy this file to .env and fill in the values.
# Never commit .env — it is gitignored.
#
# Quick start:
#   cp .env.example .env
#   # Edit .env with your values
#   pnpm install
#   pnpm --filter @workspace/db run push
#   pnpm --filter @workspace/api-server run dev   # in one terminal
#   pnpm --filter @workspace/dashboard run dev    # in another terminal
#
# On first startup, the API server auto-creates the admin user from
# ADMIN_USERNAME + ADMIN_PASSWORD if no admin user exists in the DB.
# After the user is created, remove those two vars from your .env.

# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string. Examples:
#   postgresql://postgres:password@localhost:5432/jobops
#   postgresql://user:pass@host:port/dbname?sslmode=require
DATABASE_URL=postgresql://postgres:password@localhost:5432/jobops

# ─── Session ──────────────────────────────────────────────────────────────────
# Random secret used to sign session cookies.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be at least 32 characters. Keep this secret — changing it invalidates all sessions.
SESSION_SECRET=change-me-to-a-random-32-plus-char-string

# ─── Admin User Bootstrap (first-run only) ────────────────────────────────────
# Set these on first startup to auto-create the admin account.
# Once the account is created, DELETE these two lines from your .env file.
# The server will refuse to create a second admin if one already exists.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=YourStrongPassword123!
ADMIN_EMAIL=admin@example.com

# ─── AI / OpenRouter ─────────────────────────────────────────────────────────
# Get your key at https://openrouter.ai/keys
AI_INTEGRATIONS_OPENROUTER_API_KEY=sk-or-v1-your-key-here
AI_INTEGRATIONS_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
CHUTES_API_KEY=your-chutes-key-here

# ─── Server Ports ─────────────────────────────────────────────────────────────
# These are set automatically by Replit. For local dev, the defaults below work.
# API server: http://localhost:5000
# Dashboard:  http://localhost:5173  (Vite default)
#
# The dashboard Vite dev server automatically proxies /api/* requests to the
# API server. Override the target with:
# API_SERVER_URL=http://localhost:5000

# ─── Notes ────────────────────────────────────────────────────────────────────
# The API server reads this .env file automatically (Node 24 --env-file-if-exists).
# No extra tooling needed — just place the file at the repo root and run:
#   pnpm --filter @workspace/api-server run dev
#
# The dashboard Vite dev server picks up Vite-prefixed vars automatically
# (anything starting with VITE_), and proxies /api to the API server.
# Run it with:
#   pnpm --filter @workspace/dashboard run dev
#
# Requires Node.js 22+ and pnpm 9+.
